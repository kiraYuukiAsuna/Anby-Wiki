# 本地开发环境变量样例。复制为 .env 后按需修改：
#   cp infra/local/.env.example infra/local/.env
# docker compose 会自动读取与 compose 文件同目录的 .env。

# ---- PostgreSQL ----
POSTGRES_DB=wiki
POSTGRES_USER=wiki
POSTGRES_PASSWORD=wiki_dev_password
POSTGRES_PORT=5432

# 应用连接串（Go API / Worker / 迁移工具，从宿主机连接）
DATABASE_URL=postgres://wiki:wiki_dev_password@localhost:5432/wiki?sslmode=disable

# ---- Redis（仅缓存 / 限流 / 协调，ADR-0003） ----
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ---- Search（内部 Beta 使用 Meilisearch；Postgres 仅 staging/fallback） ----
SEARCH_BACKEND=meilisearch
MEILI_PORT=7700
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=local-development-master-key
MEILI_API_KEY=local-development-master-key
MEILI_INDEX=anby_pages
MEILI_TIMEOUT=15s

# ---- MinIO / S3（对象存储，ADR-0004） ----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_dev
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=wiki-assets

# 应用侧 S3 配置（aws-sdk-go-v2，endpoint 指向本地 MinIO）
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=wiki-assets
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin_dev

# ---- AI 来源导入（Worker，可选） ----
# 默认关闭；启用后 Worker 才会领取 /imports 创建的任务。
AI_IMPORT_ENABLED=false
AI_PROVIDER=openai-compatible
AI_BASE_URL=https://api.example.com/v1
AI_API_KEY=
AI_MODEL=

# ---- Observability（Prometheus + OTLP，可选） ----
WORKER_METRICS_ADDR=:9091
OBSERVABILITY_DB_INTERVAL=30s
PROMETHEUS_PORT=9090
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_TRACE_SAMPLE_RATE=1
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
OTEL_HEALTH_PORT=13133

# ---- 浏览器写请求来源（逗号分隔；production 仅允许 HTTPS 精确 origin） ----
TRUSTED_ORIGINS=http://localhost:3000,http://localhost:8000

# ---- Nginx 网关（可选，profile=gateway） ----
NGINX_PORT=8000
